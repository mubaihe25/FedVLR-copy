{
  "model": "FedAvg",
  "dataset": "AMAZON_BEAUTY_POC",
  "scenario": "attack_only",
  "type": "AmazonBeautyPOCTargetInjectionSmoke",
  "comment": "amazon_beauty_poc_target_injection_smoke",
  "enabled_attacks": ["target_interaction_injection"],
  "enabled_defenses": [],
  "enabled_privacy_metrics": [],
  "malicious_client_config": { "enabled": true, "mode": "ratio", "ratio": 0.2, "client_ids": [] },
  "training_params": {
    "epochs": 3,
    "local_epochs": 1,
    "clients_sample_ratio": 0.1,
    "learner": "adam",
    "use_gpu": false,
    "eval_step": 1,
    "collect_round_metrics": true,
    "save_recommended_topk": true,
    "lr": 0.001,
    "l2_reg": 0.00001
  },
  "attack_params": {
    "target_interaction_injection": {
      "enabled": true,
      "target_item_ids": ["1", "0", "2", "6", "7"],
      "target_item_strategy": "explicit",
      "injection_ratio": 0.5,
      "malicious_client_ratio": 0.2,
      "max_injections_per_client": 5,
      "output_json": "target_interaction_plan.json"
    }
  },
  "defense_params": {},
  "privacy_params": {},
  "extra_config": {
    "smoke_only": true,
    "planner_only": false,
    "in_memory_hook_enabled": true,
    "does_not_modify_dataset_files": true,
    "image_features_note": "URL-hash placeholder, not visual embeddings"
  }
}
