{
  "model": "FedAvg",
  "dataset": "KU",
  "scenario": "attack_and_defense",
  "type": "SecurityMatrixSmoke",
  "comment": "krum_smoke",
  "enabled_attacks": ["poisoning_attack"],
  "enabled_defenses": ["krum"],
  "enabled_privacy_metrics": [],
  "malicious_client_config": { "enabled": true, "mode": "ratio", "ratio": 0.2, "client_ids": [] },
