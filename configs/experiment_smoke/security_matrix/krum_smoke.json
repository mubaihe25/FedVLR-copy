    "local_epochs": 1,
    "clients_sample_ratio": 0.05,
    "learner": "adam",
    "use_gpu": false,
    "eval_step": 1,
    "collect_round_metrics": true,
    "lr": 0.001,
    "l2_reg": 0.00001
