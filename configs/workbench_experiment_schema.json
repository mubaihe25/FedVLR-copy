  "parameter_descriptors": {
    "dataset": {"type": "enum", "label": "数据集", "options": ["AMAZON_BEAUTY_POC", "KU"], "help_text": "前端只展示 Amazon Beauty 和 KU 多模态数据集。"},
    "model": {"type": "enum", "label": "模型", "options": ["FedAvg", "FedRAP", "FedNCF", "FCF", "MMFedAvg", "MMFedRAP", "MMFedNCF", "MMFCF"], "help_text": "8 个模型均可进入配置；全量训练支持边界由 validate 返回。"},
    "epochs": {"type": "number", "label": "训练轮数", "min": 1, "max": 100, "step": 1, "default": 10, "help_text": "按前端提交值进入真实训练配置。"},
    "local_epochs": {"type": "number", "label": "本地轮数", "min": 1, "max": 5, "step": 1, "default": 5, "help_text": "按前端提交值进入真实训练配置。"},
    "client_sampling_ratio": {"type": "number", "label": "客户端采样比例", "min": 0.05, "max": 1.0, "step": 0.05, "default": 0.25, "unit": "ratio", "help_text": "按前端提交值进入真实训练配置。"},
    "client_count": {"type": "number", "label": "客户端数", "min": 1, "max": 5000, "step": 1, "default": 100},
    "learning_rate": {"type": "number", "label": "学习率", "min": 0.00001, "max": 0.1, "step": 0.00001, "default": 0.001, "help_text": "推荐范围 0.0001～0.01，常用值 0.001。"},
    "weight_decay": {"type": "number", "label": "权重衰减", "min": 0, "max": 0.01, "step": 0.000001, "default": 0, "help_text": "优化器 L2 正则，不是防御参数；推荐范围 0～0.001，常用值 0、0.00001、0.0001。"},
    "gradient_clip": {"type": "number", "label": "梯度裁剪上限", "min": 0.1, "max": 20, "step": 0.1, "default": 5, "help_text": "四个方向共用的训练梯度裁剪上限。"},
    "batch_size": {"type": "enum", "label": "批大小", "options": [32, 64, 128, 256], "default": 128},
    "seed": {"type": "number", "label": "随机种子", "min": 0, "max": 999999, "step": 1, "default": 2026},
    "target_item": {"type": "target_item", "label": "目标商品", "depends_on": ["dataset"], "visible_when": {"direction": "recommendation_manipulation"}, "help_text": "使用中文短名、缩略图和 item id 搜索。"},
    "malicious_client_ratio": {"type": "number", "label": "恶意客户端比例", "min": 0, "max": 0.5, "step": 0.05, "default": 0.2, "visible_when": {"direction": "recommendation_manipulation"}},
    "injection_ratio": {"type": "number", "label": "注入比例", "min": 0, "max": 0.5, "step": 0.05, "default": 0.2, "visible_when": {"direction": "recommendation_manipulation"}},
    "max_injections_per_client": {"type": "number", "label": "每客户端注入上限", "min": 1, "max": 50, "step": 1, "default": 10, "visible_when": {"direction": "recommendation_manipulation"}},
    "attack_strength": {"type": "enum", "label": "攻击强度", "options": ["weak", "medium", "strong"], "option_labels": {"weak": "弱", "medium": "中", "strong": "强"}, "value_map": {"weak": 0.5, "medium": 1.0, "strong": 2.0}, "default": "strong", "visible_when": {"direction": "recommendation_manipulation"}},
    "target_loss_weight": {"type": "number", "label": "目标损失权重", "min": 0, "max": 5, "step": 0.1, "default": 1.0, "visible_when": {"direction": "recommendation_manipulation"}, "help_text": "当前 target promotion loss 仍是可行性边界。"},
    "target_rank_selector": {"type": "enum", "label": "目标排名统计口径", "options": ["unmasked_rank", "masked_top50", "both"], "option_labels": {"unmasked_rank": "全候选排名", "masked_top50": "最终 Top50 曝光", "both": "两种口径"}, "default": "both", "visible_when": {"direction": "recommendation_manipulation"}},
    "save_topk": {"type": "boolean", "label": "导出 Top50 推荐列表", "default": true, "visible_when": {"direction": "recommendation_manipulation"}},
    "export_artifact": {"type": "boolean", "label": "导出审计结果", "default": true},
    "mia_evidence_source": {"type": "enum", "label": "MIA 证据源", "options": ["rank", "unmasked rank", "checkpoint score", "auto"], "default": "auto", "visible_when": {"direction": "membership_inference"}},
    "label_source": {"type": "enum", "label": "成员标签来源", "options": ["membership labels", "scenario labels", "auto labels"], "default": "membership labels", "visible_when": {"direction": "membership_inference"}},
    "threshold_strategy": {"type": "enum", "label": "阈值策略", "options": ["auto", "median", "fixed"], "default": "auto", "visible_when": {"direction": "membership_inference"}, "help_text": "fixed 使用 0.5（逻辑回归概率）或方向归一化后的 0 分界。"},
    "mia_model": {"type": "enum", "label": "MIA 模型", "options": ["threshold", "logistic_probe", "rank_proxy"], "default": "rank_proxy", "visible_when": {"direction": "membership_inference"}},
    "membership_sample_count": {"type": "number", "label": "样本数", "min": 1, "max": 5000, "step": 20, "default": 200, "visible_when": {"direction": "membership_inference"}},
    "member_nonmember_ratio": {"type": "number", "label": "训练/非训练记录比例", "min": 0.1, "max": 10, "step": 0.1, "default": 1, "visible_when": {"direction": "membership_inference"}},
    "update_input_source": {"type": "enum", "label": "输入来源", "options": ["client_update", "participant_params", "item_embedding"], "default": "client_update", "visible_when": {"direction": "update_leakage"}},
    "candidate_k": {"type": "enum", "label": "返回候选数量", "options": [10, 20, 50], "default": 50, "visible_when": {"direction": "update_leakage"}},
    "candidate_pool_size": {"type": "number", "label": "候选池大小", "min": 10, "max": 5000, "step": 10, "default": 500, "visible_when": {"direction": "update_leakage"}},
    "risk_modality": {"type": "enum", "label": "风险模态", "options": ["item embedding", "image", "text"], "default": "item embedding", "visible_when": {"direction": "update_leakage"}},
    "similarity_method": {"type": "enum", "label": "相似度方法", "options": ["cosine", "dot", "l2"], "default": "cosine", "visible_when": {"direction": "update_leakage"}},
    "aggregation_mode": {"type": "enum", "label": "聚合模式", "options": ["plain_updates", "secure_aggregation"], "default": "plain_updates", "disabled_when": {"robust_aggregators": "non_empty"}, "help_text": "安全聚合模拟与逐客户端鲁棒聚合互斥。"},
    "base_attack": {"type": "enum", "label": "基础攻击", "options": ["none", "malicious_update"], "default": "none", "visible_when": {"direction": "aggregation_defense"}, "help_text": "无攻击时不注入恶意客户端更新；恶意模型更新保留攻击参数。"},
    "robust_aggregators": {"type": "multi_enum", "label": "鲁棒算法", "options": ["Krum", "Median", "TrimmedMean", "Bulyan"], "option_labels": {"Krum": "Krum 异常更新筛选", "Median": "坐标中位数聚合", "TrimmedMean": "截尾均值聚合", "Bulyan": "Bulyan 组合鲁棒聚合"}, "default": [], "max_items": 1, "disabled_when": {"aggregation_mode": "secure_aggregation"}, "help_text": "单次实验最多选择一个鲁棒聚合算法；空选表示普通 FedAvg 聚合。"},
    "krum_f": {"type": "number", "label": "Krum 容错恶意客户端数", "min": 0, "step": 1, "default": 1, "dynamic_max": "floor((sampled_client_count - 3) / 2)", "visible_when": {"robust_aggregators": "Krum"}},
    "multi_krum_enabled": {"type": "boolean", "label": "多候选 Krum", "default": false, "visible_when": {"robust_aggregators": "Krum"}},
    "distance_metric": {"type": "enum", "label": "距离度量", "options": ["cosine", "l2"], "option_labels": {"cosine": "余弦距离", "l2": "L2 欧氏距离"}, "default": "cosine", "visible_when": {"robust_aggregators": "Krum"}},
    "gradient_clip_norm": {"type": "number", "label": "防御预处理裁剪上限", "min": 0.1, "max": 20, "step": 0.1, "default": 5, "visible_when": {"robust_aggregators": ["Krum", "Median"]}, "help_text": "鲁棒聚合前的独立裁剪参数，不与更新扰动层的扰动前梯度裁剪上限共用。"},
    "outlier_strategy": {"type": "enum", "label": "异常值策略", "options": ["clip", "drop", "winsorize"], "option_labels": {"clip": "裁剪", "drop": "丢弃", "winsorize": "缩尾处理"}, "default": "clip", "visible_when": {"robust_aggregators": "Median"}},
    "trim_ratio": {"type": "number", "label": "截尾比例", "min": 0, "max": 0.45, "step": 0.05, "default": 0.2, "visible_when": {"robust_aggregators": "TrimmedMean"}},
    "trim_min_keep": {"type": "number", "label": "最少保留客户端数", "min": 2, "step": 1, "default": 2, "dynamic_max": "sampled_client_count", "visible_when": {"robust_aggregators": "TrimmedMean"}},
    "bulyan_f": {"type": "number", "label": "Bulyan 容错恶意客户端数", "min": 0, "step": 1, "default": 1, "dynamic_max": "floor((sampled_client_count - 3) / 4)", "visible_when": {"robust_aggregators": "Bulyan"}},
    "bulyan_selection_ratio": {"type": "number", "label": "候选选择比例", "min": 0.25, "max": 1, "step": 0.05, "default": 0.5, "visible_when": {"robust_aggregators": "Bulyan"}},
    "dp_noise_enabled": {"type": "boolean", "label": "差分隐私风格加噪", "default": false, "help_text": "当前为差分隐私风格裁剪与加噪，没有正式隐私会计器，不展示 ε。"},
    "noise_multiplier": {"type": "number", "label": "噪声乘数", "min": 0, "max": 2, "step": 0.05, "default": 0.15, "visible_when": {"dp_noise_enabled": true}},
    "max_grad_norm": {"type": "number", "label": "扰动前梯度裁剪上限", "min": 0.1, "max": 20, "step": 0.1, "default": 5, "visible_when": {"dp_noise_enabled": true}},
    "target_delta": {"type": "enum", "label": "目标 δ（仅记录）", "options": [0.001, 0.0001, 0.00001, 0.000001], "default": 0.00001, "visible_when": {"dp_noise_enabled": true}},
    "dp_seed": {"type": "number", "label": "扰动随机种子", "min": 0, "max": 999999, "step": 1, "default": 2026, "visible_when": {"dp_noise_enabled": true}}
  },
