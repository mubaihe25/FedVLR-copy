{
  "version": "2026-06-workbench-v1",
  "description": "Bounded FedVLR workbench smoke schema for frontend orchestration. This schema validates demo/smoke jobs only and does not imply a full training run.",
  "directions": [
    {
      "id": "recommendation_manipulation",
      "label": "推荐操纵",
      "default_dataset": "AMAZON_BEAUTY_POC",
      "default_model": "FedAvg",
      "default_scenario_id": "amazon_beauty_poc_security_v3"
    },
    {
      "id": "membership_inference",
      "label": "成员推断",
      "default_dataset": "AMAZON_BEAUTY_POC",
      "default_model": "FedAvg",
      "default_scenario_id": "amazon_beauty_poc_security_v3"
    },
    {
      "id": "update_leakage",
      "label": "更新泄露",
      "default_dataset": "AMAZON_BEAUTY_POC",
      "default_model": "FedAvg",
      "default_scenario_id": "amazon_beauty_poc_security_v3"
    },
    {
      "id": "aggregation_defense",
      "label": "聚合防御",
      "default_dataset": "KU",
      "default_model": "MMFedRAP",
      "default_scenario_id": "security_matrix_krum_demo"
    }
  ],
  "datasets": [
    {
      "id": "AMAZON_BEAUTY_POC",
      "label": "Amazon Beauty",
      "short_label": "Amazon Beauty",
      "modalities": ["interaction", "text", "url_hash_image_placeholder"]
    },
    {
      "id": "KU",
      "label": "KU 多模态数据集",
      "short_label": "KU",
      "modalities": ["interaction", "text", "image"]
    }
  ],
  "models": [
    {"id": "FedAvg", "label": "FedAvg", "status": "smoke_supported", "datasets": ["AMAZON_BEAUTY_POC", "KU"]},
    {"id": "FedRAP", "label": "FedRAP", "status": "smoke_supported", "datasets": ["KU"]},
    {"id": "FedNCF", "label": "FedNCF", "status": "smoke_supported", "datasets": ["KU"]},
    {"id": "FCF", "label": "FCF", "status": "partial", "datasets": ["KU"]},
    {"id": "MMFedAvg", "label": "MMFedAvg", "status": "smoke_supported", "datasets": ["KU"]},
    {"id": "MMFedRAP", "label": "MMFedRAP", "status": "smoke_supported", "datasets": ["KU"]},
    {"id": "MMFedNCF", "label": "MMFedNCF", "status": "smoke_supported", "datasets": ["KU"]},
    {"id": "MMFCF", "label": "MMFCF", "status": "partial", "datasets": ["KU"]}
  ],
  "adapter_required_models": [
    {"id": "MGCN", "label": "MGCN", "reason": "model/trainer adapter required"},
    {"id": "MMGCN", "label": "MMGCN", "reason": "model/trainer adapter required"},
    {"id": "MMMGCN", "label": "MMMGCN", "reason": "alias requires implementation adapter"},
    {"id": "MultiModalMGCN", "label": "MultiModalMGCN", "reason": "alias requires implementation adapter"}
  ],
  "aggregation_visibility_modes": [
    {"id": "plain_updates", "label": "明文更新聚合", "allows_robust_aggregation": true},
    {"id": "secure_aggregation", "label": "安全聚合模拟", "allows_robust_aggregation": false}
  ],
  "robust_aggregators": ["Krum", "Median", "TrimmedMean", "Bulyan"],
  "direction_parameters": {
    "recommendation_manipulation": [
      "dataset",
      "model",
      "target_item",
      "epochs",
      "local_epochs",
      "client_sampling_ratio",
      "malicious_client_ratio",
      "injection_ratio",
      "max_injections_per_client",
      "attack_strength",
      "learning_rate",
      "weight_decay",
      "batch_size",
      "save_topk",
      "export_audit"
    ],
    "membership_inference": [
      "dataset",
      "model",
      "evidence_source",
      "label_source",
      "sample_count",
      "threshold_strategy",
      "learning_rate",
      "weight_decay",
      "export_pair_scores",
      "export_audit"
    ],
    "update_leakage": [
      "dataset",
      "model",
      "candidate_count",
      "hit_k",
      "risk_modality",
      "client_count",
      "learning_rate",
      "weight_decay",
      "export_reconstruction",
      "export_audit"
    ],
    "aggregation_defense": [
      "dataset",
      "model",
      "base_attack",
      "epochs",
      "local_epochs",
      "client_sampling_ratio",
      "malicious_client_ratio",
      "learning_rate",
      "weight_decay",
      "gradient_clip_norm",
      "robust_aggregators",
      "krum_f",
      "median_clip_norm",
      "trimmed_mean_ratio",
      "bulyan_f",
      "dp_style_noise_enabled",
      "dp_noise_sigma",
      "secure_aggregation_enabled"
    ]
  },
  "defense_parameters": {
    "Krum": ["krum_f", "distance_metric"],
    "Median": ["median_clip_norm"],
    "TrimmedMean": ["trimmed_mean_ratio"],
    "Bulyan": ["bulyan_f", "bulyan_selection_ratio"],
    "dp_style_noise": ["dp_noise_sigma", "gradient_clip_norm"]
  },
  "compatibility_matrix": {
    "AMAZON_BEAUTY_POC": ["FedAvg"],
    "KU": ["FedAvg", "FedRAP", "FedNCF", "FCF", "MMFedAvg", "MMFedRAP", "MMFedNCF", "MMFCF"]
  },
  "bounds": {
    "max_epochs": 10,
    "default_epochs": 10,
    "max_total_rounds": 10,
    "default_total_rounds": 10,
    "max_local_epochs": 5,
    "default_local_epochs": 5,
    "max_client_sampling_ratio_default": 0.2,
    "max_client_sampling_ratio_explicit": 1.0,
    "default_client_sampling_ratio": 0.2,
    "min_malicious_client_ratio": 0.0,
    "max_malicious_client_ratio": 0.6,
    "default_malicious_client_ratio": 0.2,
    "max_membership_sample_count": 5000,
    "default_membership_sample_count": 200,
    "candidate_k_values": [10, 20, 50],
    "batch_size_values": [64, 128, 256, 512],
    "default_batch_size": 128
  },
  "defaults": {
    "learning_rate": 0.001,
    "weight_decay": 0.0,
    "gradient_clip": 5.0,
    "trim_ratio": 0.2,
    "krum_f": 1,
    "bulyan_f": 1,
    "dp_noise_std": 0.15,
    "batch_size": 128,
    "median_clip_norm": 5.0,
    "distance_metric": "euclidean",
    "bulyan_selection_ratio": 0.5,
    "base_attack": "random_poisoning",
    "threshold_strategy": "auto",
    "label_source": "membership_labels",
    "export_pair_scores": true,
    "export_reconstruction": true,
    "injection_ratio": 0.2,
    "max_injections_per_client": 10,
    "attack_strength": "strong",
    "save_topk": true,
    "export_artifact": true
  }
}
