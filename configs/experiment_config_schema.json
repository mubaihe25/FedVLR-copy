{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FedVLR Unified Experiment Config",
  "version": "0.1.1",
  "description": "统一实验配置草案，用于 FedVLR 内部 launcher、后续 API 与前端配置页对齐。当前为轻量 schema，不引入额外运行时依赖。",
  "type": "object",
  "required": ["model", "dataset", "scenario"],
  "properties": {
    "model": {
      "type": "string",
      "description": "模型名称，例如 FedRAP、MMFedRAP、PFedRec。"
    },
    "dataset": {
      "type": "string",
      "default": "KU",
      "description": "数据集名称。当前推荐 KU。"
    },
    "scenario": {
      "type": "string",
      "enum": ["baseline", "attack_only", "defense_only", "attack_and_defense", "privacy_observation", "custom"],
      "description": "实验场景标签。launcher 会根据 enabled_* 给出已验证/未验证提示。"
    },
    "type": {
      "type": "string",
      "default": "LauncherExperiment",
      "description": "FedVLR 输出目录中的 type 字段。"
    },
    "comment": {
      "type": "string",
      "default": "launcher_experiment",
      "description": "FedVLR 输出文件名中的 comment 字段。"
    },
    "enabled_attacks": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "maxItems": 2,
      "description": "启用的攻击/攻击样式观测模块列表。推荐使用 poisoning_attack 作为统一非定向投毒入口；旧的 client_update_scale、sign_flip、model_replacement 仍兼容，适合消融或策略对比。client_preference_leakage_probe 是只读隐私泄露探针，不属于主动投毒。执行顺序等于列表顺序。"
    },
    "enabled_defenses": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "启用的防御模块列表。推荐使用 robust_defense 作为统一鲁棒防御入口；旧的 norm_clip、update_filter、trimmed_mean 仍兼容，适合消融或策略对比。client_update_anomaly 是只读检测/解释模块，不属于主动鲁棒防御。执行顺序等于列表顺序，未验证组合会给出 warning。"
    },
    "enabled_privacy_metrics": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "maxItems": 3,
      "description": "启用的隐私观测 / 评估模块列表。"
    },
    "malicious_client_config": {
      "type": "object",
      "description": "恶意客户端占位配置。未启用攻击时可保持 enabled=false。",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "mode": { "type": "string", "enum": ["none", "ratio", "fixed"], "default": "none" },
        "ratio": { "type": "number", "default": 0.0 },
        "client_ids": {
          "type": "array",
          "items": { "type": ["string", "integer"] },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "training_params": {
      "type": "object",
      "description": "训练参数。launcher 会先填入安全默认值，再合并模型推荐覆盖项与该对象。",
      "properties": {
        "epochs": { "type": "integer", "default": 1 },
        "local_epochs": { "type": "integer", "default": 1 },
        "clients_sample_ratio": { "type": "number", "default": 1.0 },
        "eval_step": { "type": "integer", "default": 1 },
        "seed": { "type": "integer", "default": 42 },
        "use_gpu": { "type": "boolean", "default": false },
        "hyper_parameters": { "type": "array", "default": [] },
        "collect_round_metrics": { "type": "boolean", "default": true },
        "save_recommended_topk": {
          "type": "boolean",
          "description": "Enable post-fit test-set TopK recommendation export through scripts/launch_experiment.py."
        },
        "recommend_topk": {
          "type": "string",
          "description": "Optional TopK output directory. Relative paths are resolved under the run result directory by the launcher."
        },
        "output_topk": {
          "type": "boolean",
          "description": "Alias for save_recommended_topk."
        },
        "save_recommend_topk": {
          "type": "boolean",
          "description": "Alias for save_recommended_topk."
        },
        "topk_export": {
          "type": "boolean",
          "description": "Alias for save_recommended_topk."
        },
        "lr": { "type": "number" },
        "l2_reg": { "type": "number" },
        "alpha": { "type": "number" },
        "beta": { "type": "number" }
      },
      "additionalProperties": true
    },
    "attack_params": {
      "type": "object",
      "description": "按模块名分组的攻击参数，例如 {\"poisoning_attack\": {\"poisoning_mix_rule\": \"round_robin\", \"poisoning_attack_scale\": 2.0}}。poisoning_attack 当前只支持非定向投毒，不支持 target item/backdoor 式定向投毒。",
      "properties": {
        "targeted_poisoning": {
          "type": "object",
          "description": "Experimental update-space targeted/preference poisoning proxy. It is not a full target-item backdoor.",
          "properties": {
            "target_item_ids": {
              "type": "array",
              "items": { "type": ["integer", "string"] }
            },
            "targeted_item_ids": {
              "type": "array",
              "items": { "type": ["integer", "string"] }
            },
            "poisoning_target_item_ids": {
              "type": "array",
              "items": { "type": ["integer", "string"] }
            },
            "targeted_poisoning_strength": { "type": "number" },
            "preference_poisoning_strength": { "type": "number" },
            "preference_direction": {
              "type": "string",
              "enum": ["increase", "decrease", "promote", "demote", "positive", "negative", "up", "down"],
              "default": "increase"
            },
            "targeted_allow_proxy_fallback": { "type": "boolean", "default": true }
          },
          "additionalProperties": true
        },
        "preference_poisoning": {
          "type": "object",
          "description": "Alias parameter group for targeted_poisoning.",
          "additionalProperties": true
        },
        "target_interaction_injection": {
          "type": "object",
          "description": "Default-off target item positive interaction injection. Without enabled=true it is planner-only; with enabled=true it mutates only malicious clients' in-memory local dataloaders and never rewrites dataset files.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false,
              "description": "When true, inject target items into malicious clients' in-memory local dataloaders. Defaults to planner-only."
            },
            "target_item_ids": {
              "type": "array",
              "items": { "type": ["integer", "string"] }
            },
            "target_item_strategy": {
              "type": "string",
              "enum": ["explicit", "high_frequency"],
              "default": "high_frequency"
            },
            "target_user_strategy": {
              "type": "string",
              "enum": ["random", "active_users", "evaluated_users", "rank_near_top_users"],
              "default": "random"
            },
            "injection_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
            "malicious_client_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
            "max_injections_per_client": { "type": "integer", "minimum": 1 },
            "repeat_target_interactions": { "type": "boolean", "default": false },
            "rating_value": { "type": "number" },
            "only_non_train_positive_targets": { "type": "boolean", "default": true },
            "target_promotion_loss": { "type": "boolean", "default": false },
            "target_promotion_loss_lambda": { "type": "number", "minimum": 0 },
            "target_promotion_loss_weight": { "type": "number", "minimum": 0 },
            "loss_weight": { "type": "number", "minimum": 0 },
            "output_json": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "defense_params": {
      "type": "object",
      "properties": {
        "median": {
          "type": "object",
          "description": "Experimental coordinate-wise median defense parameters. The current implementation has no required parameters.",
          "additionalProperties": true
        },
        "krum": {
          "type": "object",
          "description": "Experimental Krum-style client selection defense parameters.",
          "properties": {
            "byzantine_count": { "type": "integer", "minimum": 0 },
            "estimated_malicious_count": { "type": "integer", "minimum": 0 },
            "multi_krum_k": { "type": "integer", "minimum": 1 },
            "distance_norm": {
              "type": "string",
              "enum": ["l1", "l2", "euclidean"],
              "default": "l2"
            }
          },
          "additionalProperties": true
        },
        "multi_krum": {
          "type": "object",
          "description": "Experimental Multi-Krum-style client selection and aggregation defense parameters.",
          "properties": {
            "byzantine_count": { "type": "integer", "minimum": 0 },
            "estimated_malicious_count": { "type": "integer", "minimum": 0 },
            "multi_krum_k": { "type": "integer", "minimum": 1 },
            "selected_client_count": { "type": "integer", "minimum": 1 },
            "distance_norm": {
              "type": "string",
              "enum": ["l1", "l2", "euclidean"],
              "default": "l2"
            }
          },
          "additionalProperties": true
        },
        "bulyan": {
          "type": "object",
          "description": "Simplified Bulyan defense: Multi-Krum candidate selection followed by coordinate-wise trimmed mean, with fallback when client count is insufficient.",
          "properties": {
            "byzantine_count": { "type": "integer", "minimum": 0 },
            "estimated_malicious_count": { "type": "integer", "minimum": 0 },
            "bulyan_candidate_count": { "type": "integer", "minimum": 1 },
            "candidate_count": { "type": "integer", "minimum": 1 },
            "trim_ratio": { "type": "number", "minimum": 0, "exclusiveMaximum": 0.5 },
            "fallback_rule": {
              "type": "string",
              "enum": ["trimmed_mean", "median"],
              "default": "trimmed_mean"
            },
            "distance_norm": {
              "type": "string",
              "enum": ["l1", "l2", "euclidean"],
              "default": "l2"
            }
          },
          "additionalProperties": true
        },
        "dp_noise": {
          "type": "object",
          "description": "Experimental central DP-style noise defense. It is not a full differential privacy accountant.",
          "properties": {
            "clip_norm": { "type": "number", "exclusiveMinimum": 0 },
            "noise_multiplier": { "type": "number", "minimum": 0 },
            "noise_std": { "type": "number", "minimum": 0 },
            "seed": { "type": "integer" }
          },
          "additionalProperties": true
        },
        "secure_aggregation_sim": {
          "type": "object",
          "description": "Simulation-only pairwise mask cancellation summary. It is not production cryptographic secure aggregation.",
          "properties": {
            "secure_agg_seed": { "type": "integer" },
            "mask_seed": { "type": "integer" },
            "secure_agg_mask_std": { "type": "number", "minimum": 0 },
            "secure_agg_max_elements": { "type": "integer", "minimum": 1 },
            "dropout_simulation": { "type": "boolean", "default": false },
            "dropout_client_count": { "type": "integer", "minimum": 0 },
            "dropout_client_ids": {
              "type": "array",
              "items": { "type": ["string", "integer"] }
            }
          },
          "additionalProperties": true
        }
      },
      "description": "按模块名分组的防御参数，例如 {\"robust_defense\": {\"robust_defense_mode\": \"trimmed_mean\", \"robust_trim_ratio\": 0.2}}。",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "privacy_params": {
      "type": "object",
      "properties": {
        "membership_inference_probe": {
          "type": "object",
          "description": "Experimental score-based membership inference probe parameters.",
          "properties": {
            "member_scores": {
              "type": "array",
              "items": { "type": "number" }
            },
            "non_member_scores": {
              "type": "array",
              "items": { "type": "number" }
            },
            "membership_threshold": { "type": "number" },
            "membership_labels": { "type": "string" },
            "label_granularity": {
              "type": "string",
              "enum": ["user_item_pair", "item_level_proxy", "row_label"]
            },
            "score_direction": {
              "type": "string",
              "enum": ["higher_is_member", "lower_is_member", "loss_lower_is_member"],
              "default": "higher_is_member"
            }
          },
          "additionalProperties": true
        },
        "membership_pair_score_export": {
          "type": "object",
          "description": "Sidecar export for membership_pair_scores.csv. Uses supplied score files when available or clearly marked TopK rank proxy; it does not fabricate model scores.",
          "properties": {
            "membership_labels": { "type": "string" },
            "recommendation_file": { "type": "string" },
            "recommendation_dir": { "type": "string" },
            "score_file": { "type": "string" },
            "checkpoint_path": { "type": "string" },
            "model_checkpoint": { "type": "string" },
            "target_rank_summary": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "array",
                  "items": { "type": "string" }
                }
              ]
            },
            "score_mode": {
              "type": "string",
              "enum": ["checkpoint_score", "unmasked_rank", "rank_proxy", "auto"],
              "default": "auto"
            },
            "model": { "type": "string" },
            "dataset": { "type": "string" },
            "output_dir": { "type": "string" },
            "output_csv": { "type": "string" },
            "output_json": { "type": "string" }
          },
          "additionalProperties": true
        },
        "gradient_leakage_probe": {
          "type": "object",
          "description": "Experimental gradient/image leakage demo probe parameters. It is not full image reconstruction.",
          "properties": {
            "sensitive_modality": {
              "type": "string",
              "enum": ["image", "multimodal", "unknown"],
              "default": "unknown"
            },
            "norm_reference": { "type": "number", "exclusiveMinimum": 0 },
            "energy_reference": { "type": "number", "exclusiveMinimum": 0 },
            "zero_threshold": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": true
        },
        "preference_inference_probe": {
          "type": "object",
          "description": "Experimental recommendation metadata/rank-based preference inference probe parameters.",
          "properties": {
            "recommendation_file": { "type": "string" },
            "recommendation_dir": { "type": "string" },
            "item_metadata": { "type": "string" },
            "item_id_group_bucket_size": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        },
        "recommendation_manipulation": {
          "type": "object",
          "description": "Sidecar metric over baseline/attack/defense TopK lists. If target_items is absent, it only reports list-shift metrics.",
          "properties": {
            "baseline_topk": { "type": "string" },
            "attack_topk": { "type": "string" },
            "defense_topk": { "type": "string" },
            "target_items": { "type": "string" },
            "topk": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        },
        "update_leakage_risk_probe": {
          "type": "object",
          "description": "Read-only real participant_params update leakage risk summary. It is not image reconstruction and does not save raw updates.",
          "properties": {
            "norm_reference": { "type": "number", "exclusiveMinimum": 0 },
            "energy_reference": { "type": "number", "exclusiveMinimum": 0 },
            "zero_threshold": { "type": "number", "minimum": 0 },
            "max_flatten_elements": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        },
        "interaction_reconstruction_probe": {
          "type": "object",
          "description": "Read-only candidate item reconstruction from item-like embedding updates. It is not full interaction history recovery or image DLG.",
          "properties": {
            "interaction_reconstruction_topk": { "type": "integer", "minimum": 1 },
            "topk": {
              "type": "integer",
              "minimum": 1,
              "description": "Backward-compatible standalone runner alias. Launcher configs should prefer interaction_reconstruction_topk to avoid colliding with evaluator topk."
            },
            "min_item_rows": { "type": "integer", "minimum": 2 },
            "interaction_file": { "type": "string" },
            "hit_k_values": {
              "type": "array",
              "items": { "type": "integer", "minimum": 1 },
              "default": [10, 20, 50]
            },
            "image_feature_file": { "type": "string" },
            "text_feature_file": { "type": "string" },
            "nearest_neighbor_expansion": { "type": "boolean", "default": false }
          },
          "additionalProperties": true
        },
        "gradient_inversion_toy": {
          "type": "object",
          "description": "Toy DLG-style gradient matching demo over synthetic tensors. It is not full FedVLR image reconstruction.",
          "properties": {
            "channels": { "type": "integer", "minimum": 1, "maximum": 3 },
            "height": { "type": "integer", "minimum": 4, "maximum": 32 },
            "width": { "type": "integer", "minimum": 4, "maximum": 32 },
            "steps": { "type": "integer", "minimum": 1, "maximum": 200 },
            "seed": { "type": "integer" }
          },
          "additionalProperties": true
        },
        "opacus_feasibility": {
          "type": "object",
          "description": "Future-work feasibility check only. It does not install Opacus or modify FedVLR training.",
          "additionalProperties": true
        },
        "opacus_toy_demo": {
          "type": "object",
          "description": "Standalone formal-DP route toy demo. It does not integrate Opacus into the FedVLR training loop.",
          "properties": {
            "sample_count": { "type": "integer", "minimum": 8 },
            "epochs": { "type": "integer", "minimum": 1, "maximum": 20 },
            "noise_multiplier": { "type": "number", "minimum": 0 },
            "max_grad_norm": { "type": "number", "exclusiveMinimum": 0 },
            "delta": { "type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1 },
            "seed": { "type": "integer" },
            "output_json": { "type": "string" }
          },
          "additionalProperties": true
        },
        "secure_aggregation_demo": {
          "type": "object",
          "description": "Standalone synthetic pairwise-mask cancellation demo. It is not a production cryptographic protocol.",
          "properties": {
            "client_count": { "type": "integer", "minimum": 2 },
            "dimension": { "type": "integer", "minimum": 1 },
            "seed": { "type": "integer" },
            "dropout_client_ids": {
              "type": "array",
              "items": { "type": ["string", "integer"] }
            },
            "output_json": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "description": "按模块名分组的观测模块参数。",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "extra_config": {
      "type": "object",
      "description": "保留给 FedVLR Config 的额外透传字段。谨慎使用。",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "multi_module_policy": {
    "execution_order": "enabled_attacks -> enabled_defenses -> enabled_privacy_metrics",
    "max_enabled_attacks": 2,
    "defense_selection_policy": "multiple_allowed_with_unverified_warnings",
    "recommended_max_enabled_defenses": 3,
    "max_enabled_privacy_metrics": 3,
    "recommended_open_combinations": [
      {
        "scenario": "baseline",
        "enabled_attacks": [],
        "enabled_defenses": [],
        "enabled_privacy_metrics": []
      },
      {
        "scenario": "attack_only",
        "enabled_attacks": ["poisoning_attack"],
        "enabled_defenses": [],
        "enabled_privacy_metrics": []
      },
      {
        "scenario": "attack_and_defense",
        "enabled_attacks": ["poisoning_attack"],
        "enabled_defenses": ["robust_defense"],
        "enabled_privacy_metrics": []
      },
      {
        "scenario": "attack_and_defense",
        "enabled_attacks": ["poisoning_attack"],
        "enabled_defenses": ["robust_defense"],
        "enabled_privacy_metrics": [],
        "defense_params": {
          "robust_defense": {
            "robust_defense_mode": "clip_then_trimmed_mean"
          }
        }
      }
    ],
    "unverified_examples": [
      {
        "enabled_attacks": ["model_replacement", "sign_flip"],
        "enabled_defenses": []
      },
      {
        "enabled_attacks": ["model_replacement"],
        "enabled_defenses": ["update_filter", "trimmed_mean"]
      }
    ]
  }
}
